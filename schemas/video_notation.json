{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LANstar Video Notation Schema v2.0",
  "description": "AI 스토리텔링 기반 페이스리스 콘텐츠 자동화를 위한 통합 비디오 노테이션 스키마. Claude API 1회 호출로 전체 영상 구조를 JSON으로 수신.",
  "type": "object",
  "required": ["metadata", "headline", "seo", "scenes", "tts_config", "thumbnail"],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "영상 메타데이터",
      "required": ["title", "category", "target_duration", "psychology_tactics", "target_persona"],
      "properties": {
        "title": { "type": "string", "description": "영상 제목 (SEO 최적화)" },
        "category": {
          "type": "string",
          "enum": ["홈오피스/재택", "선정리/인테리어", "영상/방송", "네트워크/서버", "트러블슈팅"]
        },
        "target_duration": { "type": "string", "description": "목표 영상 길이 (예: 5-8분)" },
        "psychology_tactics": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Value Compression", "Comprehension Maxing", "Hawkeye Narrative", "Visual Stun Gun", "Contrast Hooking"]
          },
          "minItems": 2,
          "description": "적용할 5대 심리전술 중 2개 이상"
        },
        "target_persona": {
          "type": "object",
          "properties": {
            "who": { "type": "string", "description": "타겟 시청자 (예: 재택근무 3년차 직장인)" },
            "pain_point": { "type": "string", "description": "핵심 고통점" },
            "desired_outcome": { "type": "string", "description": "원하는 결과" }
          }
        },
        "product_info": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "model": { "type": "string" },
            "key_features": { "type": "array", "items": { "type": "string" } },
            "price_range": { "type": "string" },
            "purchase_url": { "type": "string" }
          }
        },
        "is_remake": { "type": "boolean", "default": false },
        "original_video_id": { "type": "string", "description": "리메이크 원본 영상 ID" }
      }
    },

    "headline": {
      "type": "object",
      "description": "제목 및 후크 라인",
      "required": ["main_title", "hook_line", "sub_title"],
      "properties": {
        "main_title": { "type": "string", "maxLength": 60, "description": "YouTube 제목 (60자 이내, SEO 키워드 포함)" },
        "hook_line": { "type": "string", "description": "5초 이내 시청자 주목 후크 (Value Compression)" },
        "sub_title": { "type": "string", "description": "보조 제목/설명" },
        "clickbait_score": { "type": "number", "minimum": 1, "maximum": 10, "description": "클릭 유도 강도 (1~10, 7이상 권장)" }
      }
    },

    "seo": {
      "type": "object",
      "description": "SEO 최적화 데이터",
      "required": ["tags", "description", "hashtags"],
      "properties": {
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 10,
          "maxItems": 30,
          "description": "YouTube 태그 (10~30개)"
        },
        "description": { "type": "string", "description": "영상 설명문 (키워드 자연 포함, 타임스탬프 포함)" },
        "hashtags": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 15,
          "description": "해시태그 (#랜스타 필수 포함)"
        },
        "primary_keyword": { "type": "string", "description": "주요 SEO 키워드" },
        "secondary_keywords": { "type": "array", "items": { "type": "string" } }
      }
    },

    "scenes": {
      "type": "array",
      "description": "장면 시퀀스 - 스크립트의 핵심",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["scene_id", "section", "duration", "narration", "visual"],
        "properties": {
          "scene_id": { "type": "integer", "description": "장면 순번 (1부터)" },
          "section": {
            "type": "string",
            "enum": ["hook", "problem", "solution", "product", "cta"],
            "description": "스크립트 구조 섹션"
          },
          "duration": { "type": "string", "description": "장면 길이 (예: 5초)" },
          "start_time": { "type": "string", "description": "시작 시간 (예: 0:00)" },

          "narration": {
            "type": "object",
            "required": ["text", "emotion", "pace"],
            "properties": {
              "text": { "type": "string", "description": "TTS용 내레이션 텍스트" },
              "emotion": {
                "type": "string",
                "enum": ["neutral", "excited", "serious", "curious", "warm", "urgent"],
                "description": "음성 감정 톤"
              },
              "pace": {
                "type": "string",
                "enum": ["slow", "normal", "fast"],
                "description": "말하기 속도"
              },
              "emphasis_words": {
                "type": "array",
                "items": { "type": "string" },
                "description": "강조할 단어 (자막 하이라이트용)"
              }
            }
          },

          "visual": {
            "type": "object",
            "required": ["type", "description"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["ai_image", "ai_video", "stock_video", "stock_image", "product_shot", "text_overlay", "screen_recording", "existing_footage"],
                "description": "영상 소스 타입"
              },
              "description": { "type": "string", "description": "시각 자료 설명" },
              "image_prompt": {
                "type": "string",
                "description": "AI 이미지 생성 프롬프트 (Flux/DALL-E용, 영어 권장)"
              },
              "camera": {
                "type": "object",
                "description": "카메라 노테이션 (브랜드 톤앤매너 일관성)",
                "properties": {
                  "shot_type": {
                    "type": "string",
                    "enum": ["wide", "medium", "close-up", "extreme-close-up", "bird-eye", "low-angle"],
                    "description": "카메라 샷 타입"
                  },
                  "lens": { "type": "string", "description": "렌즈 타입 (예: 24mm, 50mm)" },
                  "aperture": { "type": "string", "description": "조리개값 (예: f/8)" },
                  "movement": {
                    "type": "string",
                    "enum": ["static", "pan-left", "pan-right", "tilt-up", "tilt-down", "zoom-in", "zoom-out", "dolly", "tracking"],
                    "description": "카메라 이동"
                  },
                  "lighting": { "type": "string", "description": "조명 설정 (예: soft studio light)" }
                }
              },
              "stock_query": { "type": "string", "description": "스톡 영상/이미지 검색 키워드 (Pexels용)" },
              "existing_video_id": { "type": "string", "description": "기존 영상에서 재활용할 경우 영상 ID" },
              "existing_timestamp": { "type": "string", "description": "기존 영상에서 추출할 구간 (예: 1:30-1:45)" }
            }
          },

          "subtitle": {
            "type": "object",
            "properties": {
              "text": { "type": "string", "description": "자막 텍스트 (내레이션과 다를 경우)" },
              "style": {
                "type": "string",
                "enum": ["default", "highlight", "large", "animated"],
                "description": "자막 스타일"
              },
              "position": {
                "type": "string",
                "enum": ["bottom", "center", "top"],
                "default": "bottom"
              }
            }
          },

          "transition": {
            "type": "string",
            "enum": ["cut", "fade", "dissolve", "slide-left", "slide-right", "zoom", "none"],
            "default": "cut",
            "description": "다음 장면으로의 트랜지션"
          },

          "bgm": {
            "type": "object",
            "properties": {
              "mood": { "type": "string", "description": "BGM 분위기 (예: upbeat, calm, tense)" },
              "volume": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.15 },
              "action": {
                "type": "string",
                "enum": ["continue", "change", "fade-in", "fade-out", "mute"],
                "default": "continue"
              }
            }
          },

          "psychology_note": {
            "type": "string",
            "description": "이 장면에 적용된 심리전술 메모 (예: Contrast Hooking - 기대치와 현실 차이 제시)"
          }
        }
      }
    },

    "tts_config": {
      "type": "object",
      "description": "TTS 전체 설정",
      "properties": {
        "full_script": { "type": "string", "description": "전체 내레이션 텍스트 (연결)" },
        "estimated_duration": { "type": "string", "description": "예상 TTS 길이" },
        "voice_style": { "type": "string", "description": "전체 보이스 스타일 가이드" }
      }
    },

    "thumbnail": {
      "type": "object",
      "description": "썸네일 생성 정보",
      "required": ["concept", "text_overlay", "image_prompt"],
      "properties": {
        "concept": { "type": "string", "description": "썸네일 컨셉 설명" },
        "text_overlay": { "type": "string", "maxLength": 20, "description": "썸네일 텍스트 (20자 이내, 임팩트)" },
        "text_color": { "type": "string", "default": "#FFFFFF" },
        "background_color": { "type": "string" },
        "image_prompt": { "type": "string", "description": "썸네일 AI 이미지 프롬프트" },
        "emotion": { "type": "string", "description": "표현할 감정/분위기" }
      }
    },

    "shorts_repurpose": {
      "type": "object",
      "description": "숏폼 리퍼포징 가이드",
      "properties": {
        "recommended_clips": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "scene_ids": { "type": "array", "items": { "type": "integer" } },
              "hook_text": { "type": "string", "description": "숏폼 전용 후크 텍스트" },
              "virality_score": { "type": "number", "minimum": 1, "maximum": 10 }
            }
          }
        },
        "vertical_crop_guide": { "type": "string", "description": "9:16 크롭 가이드" }
      }
    }
  }
}
